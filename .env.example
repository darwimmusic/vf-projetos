# ─────────────────────────────────────────────────────────────
# VF · PROJETOS — Variáveis de ambiente (template)
# Copie para `.env.local` e preencha. NUNCA comite `.env.local`.
# Em prod, defina via `vercel env add`.
# ─────────────────────────────────────────────────────────────

# Firebase (cliente — VITE_ prefix expõe no bundle, são valores PÚBLICOS)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firebase emulator (dev only, nunca em prod)
VITE_USE_FIREBASE_EMULATOR=false

# ─────────────────────────────────────────────────────────────
# SCRIPTS ADMIN (Admin SDK — NUNCA expor com VITE_)
# Estes paths apontam para arquivos JSON gitignored
# ─────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_NEW=./service-account-rrt-vault.json
FIREBASE_SERVICE_ACCOUNT_OLD=./service-account-projeto-01.json

# Senha inicial do admin (override do default 'Farofa')
SEED_ADMIN_PASSWORD=
