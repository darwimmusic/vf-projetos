{
  "name": "vf-projetos",
  "private": true,
  "version": "0.1.0",
  "description": "VF · PROJETOS — Sistema de gestão pessoal",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --max-warnings 0",
    "format": "prettier --write .",
    "test": "vitest",
    "test:rules": "firebase emulators:exec --only firestore,storage \"vitest run tests/rules\"",
    "emulators": "firebase emulators:start",
    "seed": "dotenv -e .env.local -- tsx scripts/seed-admin.ts",
    "inspect:legacy": "dotenv -e .env.local -- tsx scripts/inspect-legacy.ts",
    "check:cross-service": "dotenv -e .env.local -- tsx scripts/check-cross-service.ts",
    "migrate": "dotenv -e .env.local -- tsx scripts/migrate-from-old-firestore.ts",
    "migrate:verify": "dotenv -e .env.local -- tsx scripts/verify-migration.ts",
    "set-role": "dotenv -e .env.local -- tsx scripts/set-user-role.ts",
    "import:rrts-dvi": "dotenv -e .env.local -- tsx scripts/import-rrts-dvi.ts",
    "import:backrooms-projeto": "dotenv -e .env.local -- tsx scripts/import-backrooms-projeto.ts",
    "fix:backrooms-billing": "dotenv -e .env.local -- tsx scripts/fix-backrooms-billing.ts",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage:rules",
    "deploy:functions": "firebase deploy --only functions",
    "secrets:scan": "tsx scripts/scan-secrets.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@tanstack/react-table": "^8.21.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.12.1",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.456.0",
    "papaparse": "^5.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.74.0",
    "react-pdf": "^9.1.1",
    "react-router-dom": "^7.0.0",
    "recharts": "^3.0.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vercel/node": "^5.7.15",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^2.1.8",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^13.29.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
